# ─── LearnJabi Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is already in .gitignore.

# ─── Google Cloud Text-to-Speech ────────────────────────────────────────────
VITE_GOOGLE_TTS_API_KEY=REPLACE_WITH_YOUR_GOOGLE_TTS_API_KEY

# ─── Supabase (Frontend) ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://ujqlpkngsgchjbikkhiv.supabase.co
VITE_SUPABASE_ANON_KEY=REPLACE_WITH_YOUR_ANON_KEY
# ─── Supabase (Server-side only — KEEP SECRET) ───────────────────────────────
# Get this from: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_YOUR_SERVICE_ROLE_KEY
